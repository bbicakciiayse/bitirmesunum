# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.so

# Virtual environments
venv/
.venv/
env/
ENV/

# Environment files
.env
backend/.env

# Model artefacts (committed separately / not in git)
backend/app/models/*.pkl
backend/app/models/*.joblib

# Uploaded data (user data, not committed)
backend/app/data/uploaded/*
backend/app/data/results/*
!backend/app/data/uploaded/.gitkeep
!backend/app/data/results/.gitkeep

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# macOS
.DS_Store

# ── Node / Frontend ───────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.env

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Vite cache
frontend/.vite/
